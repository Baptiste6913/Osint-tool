# ================================================================
# OSINT Contact Finder v6.0 — Clés API
# Copiez ce fichier en .env et remplissez vos clés
# ================================================================

# -------- v5 (toujours requis/recommandés) --------

# JINA AI (RECOMMANDÉ) — https://jina.ai/?sui=apikey
# Gratuit : 10M tokens. Sans compte requis.
# Peut être remplacé par Serper ou Tavily (voir plus bas).
JINA_API_KEY=

# HUNTER.IO (RECOMMANDÉ) — https://hunter.io/users/sign_up
# Gratuit : 25 recherches + 50 vérifications/mois
HUNTER_API_KEY=

# SNOV.IO (OPTIONNEL) — https://app.snov.io/register (50 crédits/mois)
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# APOLLO.IO (OPTIONNEL) — https://www.apollo.io/sign-up (50 crédits/mois)
APOLLO_API_KEY=

# PAPPERS.FR (OPTIONNEL, très utile FR) — https://www.pappers.fr/api (100 jetons)
PAPPERS_API_KEY=

# ABSTRACT API (OPTIONNEL) — 100 vérifs/mois
# https://www.abstractapi.com/api/email-verification-validation-api
ABSTRACT_API_KEY=

# -------- v6 (nouvelles sources gratuites) --------

# GITHUB TOKEN (OPTIONNEL) — 60/h → 5000/h avec token
# https://github.com/settings/tokens (scope "public_repo" suffit)
GITHUB_TOKEN=

# SERPER.DEV (FALLBACK #1 de JINA) — 2 500 recherches gratuites
# https://serper.dev
SERPER_API_KEY=

# TAVILY (FALLBACK #2) — 1 000 recherches/mois
# https://tavily.com
TAVILY_API_KEY=

# BING WEB SEARCH (FALLBACK #3) — 1 000/mois gratuit (Azure tier F1)
BING_SEARCH_KEY=

# EMAILREP.IO (2e VÉRIF + RÉPUTATION) — 100/j sans clé, 1000/j avec
# https://emailrep.io
EMAILREP_API_KEY=

# SECURITYTRAILS (SUBDOMAIN ENUM) — PAYANT depuis 2024 (~500$/mois min)
# Le code gère la clé si tu as un compte pro. Sinon laisser vide.
# https://securitytrails.com/corp/api
SECURITYTRAILS_API_KEY=

# UK COMPANIES HOUSE (équivalent UK de Pappers) — gratuit
# https://developer-specs.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# -------- Config server --------

PORT=3000
CACHE_TTL_HOURS=24
DOMAIN_CACHE_TTL_HOURS=168
AUDIT_RETENTION_DAYS=1095
