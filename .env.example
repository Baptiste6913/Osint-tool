# === CLÉS API OSINT Contact Finder v4 ===
# Copiez ce fichier en .env et remplissez vos clés

# JINA AI (REQUIS) — https://jina.ai/?sui=apikey
# Gratuit : 10M tokens, pas besoin de créer un compte
# Sur la page, cliquez "API" puis "API KEY & BILLING" et copiez la clé jina_xxx
JINA_API_KEY=

# HUNTER.IO (RECOMMANDÉ) — https://hunter.io/users/sign_up
# Gratuit : 25 recherches + 50 vérifications/mois
# Créez un compte → Account Settings → API → copiez la clé
HUNTER_API_KEY=

# SNOV.IO (OPTIONNEL) — https://app.snov.io/register
# Gratuit : 50 crédits/mois
# Créez un compte → https://app.snov.io/api-setting → copiez Client ID et Client Secret
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# APOLLO.IO (OPTIONNEL) — https://www.apollo.io/sign-up
# Gratuit : 50 crédits email/mois, accès à 275M+ contacts
# Créez un compte → Settings → Integrations → API → copiez la clé API
APOLLO_API_KEY=

# PAPPERS.FR (OPTIONNEL mais très utile pour les entreprises FR)
# https://www.pappers.fr/api → créez un compte avec email pro → 100 crédits gratuits
# Depuis votre espace membre, activez la clé API et copiez-la
PAPPERS_API_KEY=

# ABSTRACT API (OPTIONNEL) — https://www.abstractapi.com/api/email-verification-validation-api
# Gratuit : 100 vérifications/mois
# Créez un compte → Dashboard → Email Validation → copiez la clé API
ABSTRACT_API_KEY=

# PORT du serveur (défaut: 3000)
PORT=3000
